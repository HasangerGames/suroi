/*
    PERKS + DESCRIPTIONS - 特权 + 简介
*/

"berserker": "狂人"
"berserker_desc": "当装备近战武器时，提升移动速度和伤害"
"second_wind": "二手风"
"second_wind_desc": "当血量低于一半时，提升移动速度"
"flechettes": "破片弹"
"flechettes_desc": "所有子弹均会分裂成三个更弱的弹片"
"sabot_rounds": "高速子弹"
"sabot_rounds_desc": "降低子弹伤害但大幅提升子弹速度和范围"
"demo_expert": "拆除专家"
"demo_expert_desc": "手榴弹增大投掷范围并在撞击时立即爆炸。"
"advanced_athletics": "高级竞技"
"advanced_athletics_desc": "在水和烟雾中获得移速提升，并且可以直接穿过树木和翻窗"
"toploaded": "顶部装载"
"toploaded_desc": "弹夹的前半子弹获得伤害提升"
"infinite_ammo": "无限子弹"
"infinite_ammo_desc": "换弹不再需要或消耗弹药"
"extended_mags": "增大弹夹"
"extended_mags_desc": "提升绝大多数枪械的弹容量"
"field_medic": "战斗医员"
"field_medic_desc": "缩短使用消耗品和救助队友所需的时间"
"close_quarters_combat": "近身战斗"
"close_quarters_combat_desc": "近战时，缩短装弹时间并且提升枪械伤害"
"low_profile": "低调"
"low_profile_desc": "减少所受到的爆炸伤害，并且把你缩小"
"combat_expert": "战斗专家"
"combat_expert_desc": "缩短装弹所需的时间"
"precision_recycling": "子弹回收"
"precision_recycling_desc": "连续命中敌人两次时返还两发子弹<br>不会返还霰弹"
"plumpkin_gamble": "南瓜赌博"
"plumpkin_gamble_desc": "随机变成一个万圣节技能"
"lycanthropy": "狼人化"
"lycanthropy_desc": "变成狼人且提升血量上限，速度和生命回复。但无法使用枪械或投掷物"
"bloodthirst": "渴血"
"bloodthirst_desc": "击杀玩家时获得四分之一的血量和肾上腺素并且短暂提升移动速度，但是会缓慢掉血"
"plumpkin_bomb": "南瓜炸弹"
"plumpkin_bomb_desc": "更改投掷物的外貌并提升投掷物的伤害，且南瓜在摧毁时会爆炸"
"shrouded": "烟雾笼罩"
"shrouded_desc": "持续在以你为中心的区域释放烟雾，使其他玩家难以看透你的位置"
"experimental_treatment": "实验治疗"
"experimental_treatment_desc": "降低血量上限但肾上腺素会一直为满"
"engorged": "暴食"
"engorged_desc": "每击杀一次玩家都会让你变大且提升血量上限"
"baby_plumpkin_pie": "小南瓜派"
"baby_plumpkin_pie_desc": "每隔十秒或击杀玩家会随机更换当前手持武器"
"costumed": "装扮"
"costumed_desc": "变成一个障碍物，有小概率变成南瓜变种"
"torn_pockets": "破口袋"
"torn_pockets_desc": "每隔两秒，从背包里随机掉落两发弹药"
"claustrophobic": "幽闭恐惧症"
"claustrophobic_desc": "在密闭空间里会降低移速"
"laced_stimulants": "过度刺激"
"laced_stimulants_desc": "肾上腺素会持续伤害而不是缓缓回复血量"
"rotten_plumpkin": "腐烂南瓜"
"rotten_plumpkin_desc": "每十秒会呕吐并减少五点生命值和肾上腺素"
"infected": "感染"
"infected_desc": "每三十秒随机切换技能。<br>每秒失去生命值。<br>感染附近的玩家。"
"immunity": "免疫"
"immunity_desc": "免疫感染十五秒"
"hollow_points": "空尖弹"
"hollow_points_desc": "枪械增伤10%，不适用于非单弹头霰弹枪。被击中的玩家将在地图上为你高亮显示五秒。"
"experimental_forcefield": "实验力场"
"experimental_forcefield_desc": "获得一个能阻挡伤害的护盾。护盾每二十秒重置。"
"thermal_goggles": "热能护目镜"
"thermal_goggles_desc": "揭示周围玩家的生命条和在地图上的位置。"
"overdrive": "过载"
"overdrive_desc": "击杀玩家后短暂提升速度并恢复生命值和肾上腺素。冷却时间为十二秒。"
"loot_baron": "战利品领主"
"loot_baron_desc": "增加战利品掉落。"
"priority_target": "众矢之的"
"priority_target_desc": "所有玩家都可在地图上看到你的位置。"
"butterfingers": "笨手笨脚"
"butterfingers_desc": "增加装填所需时间。"
"overweight": "超重"
"overweight_desc": "增加你的大小。"
"overclocked": "超频"
"overclocked_desc": "提高枪械射速，但代价是增大子弹扩散。"
"plumpkin_shuffle": "楠瓜洗牌"
"plumpkin_shuffle_desc": "随机分配你的所有武器、装备、弹药、消耗品和服装。"
"eternal_magnetism": "恒磁性"
"eternal_magnetism_desc": "吸取附近玩家的生命值。<br>吸引附近的战利品。"
"last_stand": "谁笑到最后"
"last_stand_desc": "在低生命值时造成双倍伤害。"
"aching_knees": "膝盖疼"
"aching_knees_desc": "你的移动控制每十秒反转一次。"
"plumpkin_blessing": "楠瓜祝福"
"plumpkin_blessing_desc": "变幻物品与破坏南瓜类障碍物时掉落高品质战利品。受到1.5倍伤害。"
"weak_stomach": "胃病"
"weak_stomach_desc": "每五秒在地上留下一滩呕吐物。<br>增大武器扩散。"
