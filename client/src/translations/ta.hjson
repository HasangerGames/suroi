"tt_desc": "<item> <desc>"
"create_team_force_start": "கட்டாயமாக ஆரம்பிக்கவும்"
"create_team_not_ready": "தயார் அல்ல"
"region_ea": "கிழக்கு ஆசியா"
"vaccine_syringe": "தடுப்பூசி"
"vaccine_syringe_desc": "50 சக்தி தரும். இருக்கும் நோயையும் உடனடியாக குனப்படுத்தும்."
"second_wind": "இரண்டாம் காற்று"
"second_wind_desc": "பாதி உடல் நிலைக்கு கீழ் இருந்தால் வேகமாக செல்லலாம்."
"flechettes": "Fléchettes"
"flechettes_desc": "அனைத்து துப்பாக்கி பொட்டுகளும் மூன்று சேதம் குறைந்த பாகங்கலாக பிரியும்."
"sabot_rounds": "Sabot Rounds"
"sabot_rounds_desc": "துப்பாக்கி பொட்டுகளின் தூரம், வேகம், மற்றும் குறி மேம்படும், ஆனால் சேதம் குறையும்."
"extended_mags": "Extended Mags"
"extended_mags_desc": "பல துப்பாக்கிகளுக்கு அதிக பொட்டுகளுடன் இருக்கும்."
"demo_expert": "Demo Expert"
"demo_expert_desc": "குண்டுகளுக்கு அதிக வீச்சு தூரம், அதுமட்டுமன்று விழுந்தவுடன் வெடித்துவிடும்."
"advanced_athletics": "Advanced Athletics"
"advanced_athletics_desc": "தண்ணியிலும், புகையிலும் அதிக வேகத்துடன் நடக்கவும், மரங்களின் வழியாக நடக்கவும், கன்னாடிகளை உடைத்து செல்லமுடியம்."
"toploaded": "Toploaded"
"toploaded_desc": "முதல் பாதி துப்பாக்கி பொட்டுகள் அதிக சேதம் செய்யும்."
"infinite_ammo": "Infinite Ammo"
"infinite_ammo_desc": "எல்லா துப்பாக்கிகளுக்கும் கனக்கில்லா பொட்டுகள் உள்ளது."
"field_medic": "Field Medic"
"field_medic_desc": "அனைத்து பானங்களும் மருந்துகளும் வேகமாக பயன்படுத்தவும், துனை வீரர்களை வேகமாக காப்பாற்றமுடியும்."
"berseker": "Berseker"
"berseker_desc": "கை ஆயுதங்கள் வைத்துக்கொண்டால் வேகமாக செல்லவும், அதிக சேதம் செய்யும்."
"close_quarters_combat": "Close Quarters"
"close_quarters_combat_desc": "துப்பாக்கிகள் சிறிய தூரங்களில் அதிக சேதம் செய்யவும், வேகமாக ரீலோட் செய்யலாம்."
"low_profile": "Low Profile"
"low_profile_desc": "உன் உடல் அளவு குறைந்து, வெடிப்புகளிலிருந்து குறைந்த சேதமே எடுப்பாய்"
"tactical_reload": "Tactical Reload"
"tactical_reload_desc": "வேகமாக ரீலோட் செய்யலாம்"
"precision_recycling": "Precision Recycling"
"precision_recycling_desc": "ஒருவரை இரண்டு பொட்டுகள் ஒன்று-பின்-ஒன்றாக சுட்டு அவரை சேதம் செய்தால், அந்த இரண்டு பொட்டுகள் உன் துப்பாக்கியை திரும்பி அடையும். <br> ஷாட்கன்களுக்கு (Shotgun) இது பொருந்தாது."
"loot_baron": "Loot Baron"
"loot_baron_desc": "மேலும் சில பொருட்களை பெட்டிகளிடமிறுந்து பெறலாம்"
"plumpkin_gamble": "Plumpkin Gamble"
"plumpkin_gamble_desc": "Picks a random Halloween perk."
"lycanthropy": "Lycanthropy"
"lycanthropy_desc": "ஒரு அதிவேகமான, அதிக உடல்நிலை, உடல் குனம், மற்றும் கை-ஆயுத சேதம் கூடியிருக்கும் ஓனாயாக மாறு! ஆனால், உன்னால் துப்பாக்கிகள் மற்றும் குன்டுகள் பயன்படுத்த முடியாது. "
"bloodthirst": "இரத்தவெறி"
"bloodthirst_desc": "ஒவ்வொரு கொலைக்கும் 25% சக்தி, 25% உடல்நிலை, மற்றும் வேகம் தரும். போக போக உடல்நிலை குறைந்துகொண்டே வரும்."
"shrouded": "Shrouded"
"shrouded_desc": "நீ நடக்கும் வழி முழுவதும் ஒரு புகை வெளியேரும். மற்றவர்கள் அதை தான்டி பாற்பது எளிதல்ல "
"experimental_treatment": "Experimental Treatment"
"experimental_treatment_desc": "எப்போதும் சக்தி இருக்கும், ஆனால் குறைந்த அதிகபட்ச உடல்நிலை"
"engorged": "Engorged"
"engorged_desc": "ஒவ்வொரு கொலைக்கும் உடல்நிலை மற்றும் உடல் அளவு அதிகமாகும்"
"baby_plumpkin_pie": "Baby Plumpkin Pie"
"baby_plumpkin_pie_desc": "உன் கையில் வைத்திறுக்கும் ஆயுதம் ஒவ்வொறு 10 வினாடிகளுக்கு ஒருமுறையும் மாறும், மற்றும் ஒவ்வொரு கொலைக்கும் மாறும்"
"costumed": "Costumed"
"costumed_desc": "ஏதோ ஒரு பொருளாக உருவம் மாறு. ப்ளம்ப்கின் (Plumpkin) ஆவதற்கு சிறிய வாய்ப்பே உள்ளது"
"torn_pockets": "கிழிந்த பாக்கெட்டு"
"torn_pockets_desc": "ஒவ்வொரு 2 வினாடிகளுக்கும், உன்னிடமிறுந்து ஏதோ 2 அம்மோ கீழே விழும்"
"claustrophobic": "Claustrophobic"
"claustrophobic_desc": "கட்டிடங்கள் மற்றும் பங்கர்கள் (சுரங்கங்கள்) நகர்வு வேகம் குறையும்"
"laced_stimulants": "Laced Stimulants"
"laced_stimulants_desc": "உன்னை குனப்படுத்தாமல், சக்தி உனக்கு பாதி குனப்படுத்தும் அளவிற்கு சேதம் செய்யும்"
"rotten_plumpkin": "அழுகிய Plumpkin"
"rotten_plumpkin_desc": "ஒவ்வொரு 10 வினாடிகளுக்கும், வாந்தி உணர்ச்சியை (Vomit Emote) வெளிப்படுத்தி, 5% சக்தி குறைந்து, 5 உடல்நிலை குறையும்"
"infected": "நோயாலி"
"infected_desc": "வேகம் மற்றும் செய்யும் சேதம் அதிகறிக்கும், ஆனால் உடல்நிலை மற்றும் சக்தி குறைந்துகொண்டே வரும். அறுகே இருக்கும் வீரர்களுக்கு பரவும்"
"immunity": "நோய் எதிர்பு-சக்தி"
"immunity_desc": "நோயிடமிருந்து 15 வினாடி எதிர்பு-சக்தி தரும்"
"hollow_points": "Hollow Points"
"hollow_points_desc": "துப்பாக்கிகள் 10% அதிக சேதம் செய்யும். slug அல்லாத ஷாட்கன்களுக்கு(Shotgun) இது பொருந்தாது. அதைவைத்து சேதம் செய்தால் வீரர்கள் வரைபடத்தில் 5 வினாடிகளுக்கு சுட்டிக்காட்டி படுவர்."
"experimental_forcefield": "Experimental Forcefield"
"thermal_goggles": "Thermal Goggles"
"thermal_goggles_desc": "அறுகேயுள்ள வீரர்களின் உடல்நிலை விவரமும் இருக்குமிடத்தை பார்க்கமுடியும்"
"overdrive": "Overdrive"
"overdrive_desc": "ஒவ்வொரு கொலைக்கும் நகர்வு வேகம், உடல்நிலை, மற்றும் சக்தி கூடும். 12 வினாடி இடைவெளியில்"
"partners": "கூட்டாளிகள்"
"username_placeholder": "உன் புனர்பெயரை செலுத்துக"